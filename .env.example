# Base de datos
DATABASE_URL="postgresql://user:password@localhost:5432/precios_pe"

# Auth
NEXTAUTH_SECRET="tu-secreto-seguro-cambiar-en-produccion"
NEXTAUTH_URL="http://localhost:3000"
CREDENTIALS_SECRET_KEY="clave-independiente-para-cifrar-credenciales"
ADMIN_SEED_PASSWORD="Admin12345!"

# OpenAI (para normalización IA)
OPENAI_API_KEY="sk-..."

# Telegram Bot
TELEGRAM_BOT_TOKEN="tu-token-del-bot"
TELEGRAM_CHAT_ID="tu-chat-id-personal-o-respaldo"
TELEGRAM_BROADCAST_CHAT_ID="@tu_canal_publico_o_-1001234567890"
TELEGRAM_BROADCAST_INVITE_URL="https://t.me/tu_canal_publico"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Scraping
MIN_MARGIN_PERCENT="15"
SCRAPE_INTERVAL_HOURS="3"
SCRAPE_HTML_BACKENDS="firecrawl,scraperapi,playwright"
FIRECRAWL_API_KEY="fc-..."
FIRECRAWL_PROXY_MODE="auto"
SCRAPERAPI_API_KEY="tu-api-key"
SCRAPERAPI_PREMIUM="true"
SCRAPERAPI_ULTRA_PREMIUM="false"
SCRAPERAPI_COUNTRY_CODE="pe"
SCRAPERAPI_DEVICE_TYPE="desktop"
# Opcional: fuerza un backend especifico para pruebas, por ejemplo `firecrawl` o `scraperapi`
# SCRAPE_HTML_BACKENDS="firecrawl"
# Opcional por proveedor: `SCRAPE_HTML_BACKENDS_MERCADOLIBRE="scraperapi,firecrawl,playwright"`

# Credenciales mayoristas (rellenar cuando tengas acceso; en producción usar secretos)
DELTRON_USER="tu-usuario"
DELTRON_PASS="tu-password"

INGRAM_USER="tu-usuario"
INGRAM_PASS="tu-password"

INTCOMEX_USER="tu-usuario"
INTCOMEX_PASS="tu-password"

MAXIMA_USER="tu-usuario"
MAXIMA_PASS="tu-password"

COMPUDISKETT_USER="tu-usuario"
COMPUDISKETT_PASS="tu-password"
